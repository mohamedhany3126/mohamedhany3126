<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mohamed Hany Portfolio</title>
<style>
body{margin:0;font-family:Arial;background:#f8fbff;color:#0f172a}
header{padding:25px 8%;display:flex;justify-content:space-between;align-items:center;background:white;box-shadow:0 2px 15px #eee}
.logo{font-size:24px;font-weight:bold;color:#0b5ed7}
nav a{margin:0 15px;text-decoration:none;color:#0f172a;font-weight:600}
.btn{background:#0b5ed7;color:white;padding:12px 22px;border-radius:8px;text-decoration:none}
.hero{display:flex;align-items:center;gap:60px;padding:70px 8%;background:white}
.hero img{width:330px;border-radius:45% 45% 10% 10%;background:#eef4ff}
.hero h1{font-size:58px;margin:0}
.hero h2{color:#0b5ed7}
.info{margin-top:25px;color:#475569}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin:20px 8%;background:white;padding:30px;border-radius:20px;box-shadow:0 10px 30px #e5e7eb}
.stat{text-align:center}
.stat h3{font-size:28px;color:#0b5ed7;margin:0}
.section{text-align:center;padding:60px 8%}
.section h2{font-size:38px;margin:5px}
.cases{display:grid;grid-template-columns:repeat(3,1fr);gap:30px;margin-top:40px}
.card{background:white;border-radius:16px;padding:15px;box-shadow:0 10px 30px #e5e7eb}
.card img{width:100%;border-radius:10px}
.card h3{margin-bottom:5px}
footer{text-align:center;padding:30px;background:#0f172a;color:white}
@media(max-width:900px){.hero,.stats,.cases{grid-template-columns:1fr;display:block}.hero{text-align:center}.hero img{width:260px}.hero h1{font-size:38px}nav{display:none}.card{margin-bottom:25px}}
</style>
</head>
<body>

<header>
  <div class="logo">MH Mohamed Hany</div>
  <nav>
    <a href="#">Home</a>
    <a href="#cases">Cases</a>
    <a href="#contact">Contact</a>
  </nav>
  <a class="btn" href="#contact">Book Appointment</a>
</header>

<section class="hero">
  <img src="profile.jpg" alt="Profile Photo">
  <div>
    <h1>Mohamed Hany.</h1>
    <h2>General Dentist</h2>
    <p>I’m passionate about helping patients achieve healthy, confident smiles through modern dentistry and personalized care.</p>
    <div class="info">📍 Cairo, Egypt &nbsp; | &nbsp; 📞 +20 101 234 5678 &nbsp; | &nbsp; ✉️ mohamed@example.com</div>
  </div>
</section>

<div class="stats">
  <div class="stat"><h3>500+</h3><p>Happy Patients</p></div>
  <div class="stat"><h3>4+</h3><p>Years Experience</p></div>
  <div class="stat"><h3>100+</h3><p>Treatments Done</p></div>
  <div class="stat"><h3>98%</h3><p>Satisfaction Rate</p></div>
</div>

<section class="section" id="cases">
  <p style="color:#0b5ed7;font-weight:bold">MY WORK</p>
  <h2>Before & After Cases</h2>

  <div class="cases">
    <div class="card">
      <img src="case1.jpg" alt="Before After Case">
      <h3>Teeth Whitening</h3>
      <p>1 Session</p>
    </div>

    <div class="card">
      <img src="case2.jpg" alt="Before After Case">
      <h3>Composite Veneers</h3>
      <p>2 Sessions</p>
    </div>

    <div class="card">
      <img src="case3.jpg" alt="Before After Case">
      <h3>Smile Makeover</h3>
      <p>4 Sessions</p>
    </div>
  </div>
</section>

<footer id="contact">
  <h3>Contact Me</h3>
  <p>WhatsApp: +20 101 234 5678</p>
</footer>

</body>
</html>
